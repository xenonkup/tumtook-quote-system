# Template สำหรับ backend (Go) — ตอน dev ไม่จำเป็นต้องสร้าง .env
# เพราะโค้ดมีค่า default สำหรับ Docker local อยู่แล้ว
# ตอน deploy ขึ้น Render ให้ตั้งค่าพวกนี้ใน Environment ของ service

# Postgres connection string
#   - dev (Docker):  postgres://postgres:devpass@localhost:5432/tumtook
#   - production:    เอา "Internal Database URL" จาก Render Postgres มาใส่
DATABASE_URL=postgres://postgres:devpass@localhost:5432/tumtook

# พอร์ตที่ service ฟัง (Render จะกำหนดให้เองตอน deploy)
PORT=8080
